-- 🔥 NOWA FUNKCJA (Twoje args)
local function openEgg(name)
    local args = {
        name,
        true,
        false,
        false
    }

    pcall(function()
        ReplicatedStorage:WaitForChild("RemoteFunction"):InvokeServer(unpack(args))
    end)
end

-- AUTO OPEN
spawn(function()
    while true do
        if auto then
            local amount = tonumber(amountBox.Text) or 100
            local delay = tonumber(speedBox.Text) or 0
            local opened = 0

            for i=1,amount do
                if not auto then break end
                spawn(function()
                    openEgg(eggBox.Text)
                end)
                opened += 1
                status.Text = "Opened: "..opened
                task.wait(delay)
            end
        else
            task.wait(0.1)
        end
    end
end)

